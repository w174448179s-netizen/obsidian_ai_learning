# ---------------- Obsidian 缓存/工作区/垃圾文件 ----------------
.obsidian/cache/
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/logs/
.obsidian/trash/
.obsidian/plugins/*/.hotreload
.obsidian/plugins/*/node_modules/
.obsidian/plugins/*/.git
.obsidian/plugins/*/package-lock.json
.obsidian/plugins/*/yarn.lock
.obsidian/plugins/*/dist/

# 本地窗口布局、会话缓存
.obsidian/sessions/
.obsidian/backup/

# ---------------- 系统生成文件 ----------------
# Mac
.DS_Store
.AppleDouble
.LSOverride
._*
# Windows
Thumbs.db
desktop.ini

# ---------------- 临时/备份文件 ----------------
*.tmp
*.bak
*.swp
*.swo
~$*

# ---------------- 可选：大附件（按需取消注释） ----------------
# 图片视频多、仓库太大时打开下面两行
# attachments/
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.mp4
# *.pdf

# ---------------- Git 嵌套冲突清理 ----------------
*/.git
*/.gitignore
*/.gitmodules
